---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/ContactForm.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';
import { SITE } from '@/config';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('nav.contact')} — ${SITE.name}`}
  description={lang === 'es'
    ? 'Escríbeme para proyectos, colaboraciones o para charlar sobre pipelines.'
    : 'Get in touch about projects, collaborations, or to chat about pipelines.'}
>
  <section class="mx-auto max-w-5xl px-[22px] pt-11 pb-16 sm:px-10 sm:pt-[76px]">
    <div data-reveal>
      <h1 class="font-display text-[40px] font-medium tracking-[-0.02em] text-ink sm:text-[52px]">
        {t('contact.title')}
      </h1>
      <p class="font-body mt-3 max-w-[30em] text-[17px] leading-[1.6] text-muted">
        {t('contact.sub')}
      </p>
      <div class="mt-9">
        <ContactForm lang={lang} />
      </div>
    </div>
  </section>
</BaseLayout>
