---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === lang && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Post id is "<lang>/<slug>"; strip the lang folder for the URL.
const slugOf = (id: string) => id.replace(/^[a-z]{2}\//, '');
---

<BaseLayout
  title={`${t('nav.blog')} — Jota Navarrete`}
  description={lang === 'es' ? 'Artículos y notas.' : 'Articles and notes.'}
>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-3xl font-bold mb-6">{t('nav.blog')}</h1>
    {posts.map((post) => (
      <BlogCard
        href={`${base}/${lang}/blog/${slugOf(post.id)}`}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
      />
    ))}
  </section>
</BaseLayout>
