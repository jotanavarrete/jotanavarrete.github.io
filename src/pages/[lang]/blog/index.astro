---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === lang && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Post id is "<lang>/<slug>"; strip the lang folder for the URL.
const slugOf = (id: string) => id.replace(/^[a-z]{2}\//, '');
---

<BaseLayout
  title={`${t('nav.blog')} — Jota Navarrete`}
  description={lang === 'es' ? 'Artículos y notas.' : 'Articles and notes.'}
>
  <section class="mx-auto max-w-5xl px-[22px] py-11 sm:px-10 sm:py-13">
    <SectionHeader kicker={t('blog.kicker')} title={t('blog.title')} sub={t('blog.sub')} />
    <div class="mt-[30px] grid grid-cols-1 gap-[18px] sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <BlogCard
          href={`${base}/${lang}/blog/${slugOf(post.id)}`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
