---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';
import { SITE } from '@/config';

export const getStaticPaths = (async () => {
  const slugOf = (id: string) => id.replace(/^[a-z]{2}\//, '');
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: slugOf(post.id) },
    props: { post, posts },
  }));
}) satisfies GetStaticPaths;

const slugOf = (id: string) => id.replace(/^[a-z]{2}\//, '');
const { post, posts } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Language switcher targets: jump to the matching translation (slugs may
// differ across languages), or fall back to that language's blog index.
const key = post.data.translationKey;
const langOverrides = Object.fromEntries(
  (Object.keys(languages) as Lang[])
    .filter((l) => l !== lang)
    .map((l) => {
      const match = key && posts.find((p) => p.data.lang === l && p.data.translationKey === key);
      const href = match ? `${base}/${l}/blog/${slugOf(match.id)}` : `${base}/${l}/blog`;
      return [l, href];
    })
) as Partial<Record<Lang, string>>;

const { Content } = await render(post);
const dateLabel = post.data.pubDate.toLocaleDateString(lang, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout
  title={`${post.data.title} — ${SITE.name}`}
  description={post.data.description}
  ogType="article"
  image={post.data.heroImage?.src}
  imageWidth={post.data.heroImage?.width}
  imageHeight={post.data.heroImage?.height}
  imageAlt={post.data.heroImage ? post.data.title : undefined}
  langOverrides={langOverrides}
>
  <article class="mx-auto max-w-3xl px-4 py-16">
    <a href={`${base}/${lang}/blog`} class="text-sm underline">← {t('blog.backToList')}</a>
    <h1 class="mt-4 text-3xl font-bold">{post.data.title}</h1>
    <time datetime={post.data.pubDate.toISOString()} class="text-sm text-gray-500">
      {dateLabel}
    </time>
    <div class="prose mt-8 max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
