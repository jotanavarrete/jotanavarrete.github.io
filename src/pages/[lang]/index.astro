---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import ExperienceSection from '@/components/ExperienceSection.astro';
import BlogSection from '@/components/BlogSection.astro';
import PersonalSection from '@/components/PersonalSection.astro';
import { languages, type Lang } from '@/i18n/ui';
import { SITE } from '@/config';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };

const content = {
  es: {
    title: `${SITE.name} — Portfolio`,
    description: 'Ingeniero de software. CV, experiencia y blog.',
  },
  en: {
    title: `${SITE.name} — Portfolio`,
    description: 'Software engineer. CV, experience and blog.',
  },
}[lang];
---

<BaseLayout title={content.title} description={content.description}>
  <Hero />
  <ExperienceSection />
  <BlogSection limit={3} />
  <PersonalSection />
  <!-- Contact section is the site-wide Footer (#contact). -->
</BaseLayout>
