---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ExperienceSection from '@/components/ExperienceSection.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('nav.experience')} — Jota Navarrete`}
  description={lang === 'es'
    ? 'Experiencia laboral y trayectoria profesional.'
    : 'Work experience and professional background.'}
>
  <ExperienceSection />
</BaseLayout>
