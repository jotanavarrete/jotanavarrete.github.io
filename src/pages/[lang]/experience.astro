---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ExperienceCard from '@/components/ExperienceCard.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import { getExperience } from '@/data/experience';
import { languages, useTranslations, type Lang } from '@/i18n/ui';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const items = getExperience(lang);
---

<BaseLayout
  title={`${t('nav.experience')} — Jota Navarrete`}
  description={lang === 'es'
    ? 'Experiencia laboral y trayectoria profesional.'
    : 'Work experience and professional background.'}
>
  <section class="mx-auto max-w-5xl px-[22px] py-11 sm:px-10 sm:py-13">
    <SectionHeader kicker={t('exp.kicker')} title={t('exp.title')} sub={t('exp.sub')} />
    <div class="mt-[34px] border-l-2 border-line pl-[26px]">
      {items.map((item) => <ExperienceCard item={item} />)}
    </div>
  </section>
</BaseLayout>
