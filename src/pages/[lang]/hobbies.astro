---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PersonalSection from '@/components/PersonalSection.astro';
import { languages, useTranslations, type Lang } from '@/i18n/ui';

export const getStaticPaths = (() =>
  (Object.keys(languages) as Lang[]).map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('nav.hobbies')} — Jota Navarrete`}
  description={lang === 'es' ? 'Intereses y hobbies personales.' : 'Personal interests and hobbies.'}
>
  <PersonalSection />
</BaseLayout>
