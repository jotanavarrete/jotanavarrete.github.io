---
import { getLangFromUrl, useTranslations } from '@/i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Routes share segments across locales; only the /es | /en prefix changes.
const experienceHref = `${base}/${lang}/experience`;
// No dedicated contact page yet — link to email until one exists.
const contactHref = 'mailto:mail@mail.com';

// Neutral, same in both languages — kept local, not a UI label.
const skills = ['Python', 'Spark', 'SQL', 'Airflow', 'dbt', 'Kafka', 'Snowflake', 'AWS'];
---

<section id="top" class="bg-bg text-ink">
  <div
    class="mx-auto grid max-w-5xl grid-cols-1 items-center gap-12 px-[22px] pt-11 pb-10 sm:grid-cols-[1.35fr_.9fr] sm:px-10 sm:pt-[76px] sm:pb-16"
  >
    <!-- Text column -->
    <div data-reveal>
      <h1
        class="font-display text-[40px] leading-[1.02] font-medium tracking-[-0.02em] sm:text-[60px]"
      >
        {t('hero.title')}
      </h1>
      <p class="font-display mt-3 text-[22px] leading-[1.1] text-accent italic sm:text-[26px]">
        {t('hero.role')}
      </p>
      <p class="font-body mt-[22px] max-w-[30em] text-[17px] leading-[1.6] text-muted">
        {t('hero.lead')}
      </p>

      <div class="mt-[30px] flex flex-wrap gap-[14px]">
        <a
          href={experienceHref}
          class="font-body rounded-[11px] bg-accent px-[22px] py-[13px] text-[15px] font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-[0_14px_26px_-12px_var(--color-accent)]"
        >
          {t('hero.ctaPrimary')}
        </a>
        <a
          href={contactHref}
          class="font-body rounded-[11px] border border-line bg-transparent px-[22px] py-[13px] text-[15px] font-semibold text-ink transition hover:-translate-y-0.5 hover:border-ink"
        >
          {t('hero.ctaSecondary')}
        </a>
      </div>

      <ul class="mt-[34px] flex flex-wrap gap-2">
        {
          skills.map((skill) => (
            <li class="font-body rounded-lg border border-line bg-card px-[11px] py-1.5 text-[12px] text-muted">
              {skill}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Photo column: placeholder ready for astro:assets <Image> -->
    <div data-reveal>
      <div
        class="relative flex aspect-[4/5] items-center justify-center overflow-hidden rounded-card border border-line bg-card"
        style="background-image: repeating-linear-gradient(45deg, var(--color-line) 0, var(--color-line) 1px, transparent 1px, transparent 13px);"
      >
        <div
          class="font-display flex h-24 w-24 items-center justify-center rounded-full bg-accent-soft text-[34px] font-semibold text-accent"
        >
          JM
        </div>
        <span
          class="font-body absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full border border-line bg-panel px-3 py-1 text-[11px] tracking-[0.08em] text-muted uppercase"
        >
          {t('hero.photoPlaceholder')}
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  // Lightweight reveal-on-scroll. CSS handles reduced-motion fallback.
  const els = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.15 }
    );
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach((el) => el.classList.add('is-visible'));
  }
</script>
