---
import { getLangFromUrl, useTranslations } from '@/i18n/ui';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { href, title, description, pubDate, tags = [] } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLabel = pubDate.toLocaleDateString(lang, {
  year: 'numeric',
  month: 'short',
  timeZone: 'UTC',
});
---

<a
  href={href}
  data-reveal
  class="flex flex-col rounded-card border border-line bg-card p-5 no-underline transition duration-[250ms] hover:-translate-y-1 hover:border-accent-soft hover:shadow-[0_22px_44px_-28px_rgba(40,30,20,0.5)]"
>
  <div class="mb-3.5 flex items-center justify-between gap-2">
    <div class="flex flex-wrap gap-1.5">
      {
        tags.map((tag) => (
          <span class="font-body rounded-[7px] bg-accent-soft px-[9px] py-1 text-[11px] tracking-[0.03em] text-accent uppercase">
            {tag}
          </span>
        ))
      }
    </div>
    <time datetime={pubDate.toISOString()} class="font-body shrink-0 text-[11px] text-muted">
      {dateLabel}
    </time>
  </div>
  <h3 class="font-display text-[18px] leading-[1.25] font-medium text-ink">{title}</h3>
  <p class="mt-2.5 mb-4 flex-1 text-[14px] leading-[1.55] text-muted">{description}</p>
  <span class="font-body text-[13px] font-semibold text-accent">{t('blog.readMore')} →</span>
</a>
