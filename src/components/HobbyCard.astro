---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---

<article class="p-6 rounded-xl border border-gray-200">
  {icon && <div class="text-3xl mb-3">{icon}</div>}
  <h3 class="text-lg font-semibold">{title}</h3>
  <p class="mt-2 text-gray-700">{description}</p>
</article>
