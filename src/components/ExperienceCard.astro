---
import type { ExperienceItem } from '@/data/experience';
import { getLangFromUrl } from '@/i18n/ui';

interface Props {
  item: ExperienceItem;
}

const { item } = Astro.props;
const lang = getLangFromUrl(Astro.url);

function formatDate(iso: string): string {
  const [year, month] = iso.split('-');
  const date = new Date(Number(year), Number(month ?? 1) - 1);
  return date.toLocaleDateString(lang, { year: 'numeric', month: 'short' });
}

const current = lang === 'es' ? 'Actualidad' : 'Present';
const end = item.endDate ? formatDate(item.endDate) : current;
---

<article class="py-6 border-b border-gray-100">
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <h3 class="text-lg font-semibold">
      {item.role} ·
      {
        item.companyUrl ? (
          <a href={item.companyUrl} class="underline" target="_blank" rel="noopener">
            {item.company}
          </a>
        ) : (
          item.company
        )
      }
    </h3>
    <span class="text-sm text-gray-500">{formatDate(item.startDate)} — {end}</span>
  </div>
  {item.location && <p class="text-sm text-gray-500">{item.location}</p>}
  <p class="mt-2 text-gray-700">{item.summary}</p>
  {
    item.highlights.length > 0 && (
      <ul class="mt-2 list-disc list-inside text-gray-700 space-y-1">
        {item.highlights.map((h) => (
          <li>{h}</li>
        ))}
      </ul>
    )
  }
  {
    item.tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {item.tags.map((tag) => (
          <li class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-600">{tag}</li>
        ))}
      </ul>
    )
  }
</article>
