---
import { languages, getLangFromUrl, switchLanguagePath, type Lang } from '@/i18n/ui';

const currentLang = getLangFromUrl(Astro.url);
const base = import.meta.env.BASE_URL;
---

<div class="flex items-center rounded-full border border-line bg-card p-[3px] text-[12px] font-medium">
  {
    (Object.keys(languages) as Lang[]).map((lang) => (
      <a
        href={switchLanguagePath(Astro.url, lang, base)}
        hreflang={lang}
        aria-current={lang === currentLang ? 'true' : undefined}
        class:list={[
          'rounded-full px-[13px] py-[5px] transition-colors',
          lang === currentLang ? 'bg-accent text-white' : 'text-muted hover:text-ink',
        ]}
      >
        {lang.toUpperCase()}
      </a>
    ))
  }
</div>
