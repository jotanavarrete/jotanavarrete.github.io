---
// Section header from the Claude Design bundle: kicker + title + subtitle.
// Reused by the experience, blog and personal sections.
interface Props {
  kicker: string;
  title: string;
  sub: string;
}

const { kicker, title, sub } = Astro.props;
---

<div data-reveal>
  <div class="font-body text-[12px] tracking-[0.16em] text-accent uppercase">{kicker}</div>
  <h2
    class="font-display mt-2 mb-1 text-[29px] font-medium tracking-[-0.015em] text-ink sm:text-[36px]"
  >
    {title}
  </h2>
  <p class="text-[16px] text-muted">{sub}</p>
</div>
